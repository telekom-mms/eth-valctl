{
  "author": {
    "name": "TobiWo"
  },
  "bin": {
    "eth-valctl": "src/cli/main.ts"
  },
  "dependencies": {
    "@chainsafe/blst": "^2.2.0",
    "@ethereumjs/common": "^10.1.1",
    "@ethereumjs/tx": "^10.1.1",
    "@ledgerhq/errors": "^6.34.0",
    "@ledgerhq/hw-app-eth": "^7.8.0",
    "@ledgerhq/hw-transport-node-hid": "^6.33.1",
    "@safe-global/api-kit": "^4.1.0",
    "@safe-global/protocol-kit": "^7.1.0",
    "@safe-global/types-kit": "^3.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ethers": "^6.16.0",
    "prompts": "^2.4.2",
    "undici": "^8.1.0"
  },
  "description": "CLI tool to manage Ethereum validators",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@eslint/migrate-config": "^2.0.6",
    "@ledgerhq/types-cryptoassets": "^7.36.0",
    "@ledgerhq/types-devices": "^6.31.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/bun": "^1.3.12",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "sort-package-json": "^3.6.1",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "name": "eth-valctl",
  "overrides": {
    "axios": "1.15.0",
    "node-hid": "3.3.0"
  },
  "packageManager": "bun@1.3.12",
  "scripts": {
    "clean": "rm -rf bin dist",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "lint": "bunx eslint . --ext .ts --fix",
    "package": "bun run scripts/package/package.ts",
    "postinstall": "bun run scripts/package/patch-native-modules.ts",
    "start": "bun run src/cli/main.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun run --bun tsc --noEmit && echo \"\u2713 TypeScript compilation successful - no errors found\""
  },
  "type": "module",
  "version": "0.6.0"
}
